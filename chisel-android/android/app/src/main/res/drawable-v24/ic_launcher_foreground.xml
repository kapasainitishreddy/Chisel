    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Faceted gem: a chiseled facet, the Chisel mark -->
    <path android:pathData="M38,38 L70,38 L82,54 L54,84 L26,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="26" android:startY="38"
                android:endX="82" android:endY="84">
                <item android:offset="0" android:color="#E2C58A"/>
                <item android:offset="0.55" android:color="#C9A86A"/>
                <item android:offset="1" android:color="#9C7E48"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Facet lines, onyx, to suggest the cut -->
    <path android:pathData="M26,54 L82,54"
        android:strokeColor="#0A0A0B" android:strokeWidth="1.6"/>
    <path android:pathData="M38,38 L45,54"
        android:strokeColor="#0A0A0B" android:strokeWidth="1.4"/>
    <path android:pathData="M70,38 L63,54"
        android:strokeColor="#0A0A0B" android:strokeWidth="1.4"/>
    <path android:pathData="M45,54 L54,84"
        android:strokeColor="#0A0A0B" android:strokeWidth="1.4"/>
    <path android:pathData="M63,54 L54,84"
        android:strokeColor="#0A0A0B" android:strokeWidth="1.4"/>

    <!-- Top highlight facet for sparkle -->
    <path android:pathData="M45,54 L54,38.6 L63,54 Z"
        android:fillColor="#F3E6C8" android:fillAlpha="0.45"/>
</vector>
